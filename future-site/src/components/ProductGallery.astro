---
import { copy, products, ui, type Lang } from "../data/site";
import { withBase } from "../utils/paths";
const { lang, limit } = Astro.props as { lang: Lang; limit?: number };
const shown = limit ? products.slice(0, limit) : products;
const text = ui[lang];
---

<section class="section gallery-section">
  <div class="section-heading split">
    <div>
      <p class="eyebrow">Sample Gallery</p>
      <h2>{copy[lang].galleryTitle}</h2>
    </div>
    <a class="text-link" href={withBase(`/${lang}/contact/`)}>
      {text.askSimilarParts}
    </a>
  </div>
  <div class="product-gallery">
    {shown.map((product) => (
      <figure class="product-tile">
        <img src={withBase(product.image)} alt={product.name[lang]} />
        <figcaption>{product.name[lang]}</figcaption>
      </figure>
    ))}
  </div>
</section>
