---
import { copy, type Lang } from "../data/site";
import { withBase } from "../utils/paths";
const { lang } = Astro.props as { lang: Lang };
const c = copy[lang];
---

<section class="hero-section">
  <div class="hero-bg" aria-hidden="true">
    <div class="scan-grid"></div>
    <div class="radar-ring radar-ring-a"></div>
    <div class="radar-ring radar-ring-b"></div>
  </div>

  <div class="hero-copy">
    <p class="eyebrow">{c.heroKicker}</p>
    <h1>{c.heroTitle}</h1>
    <p>{c.heroText}</p>
    <div class="hero-actions">
      <a class="button primary" href={withBase(`/${lang}/contact/`)}>{c.primaryCta}</a>
      <a class="button ghost" href={withBase(`/${lang}/materials/`)}>{c.secondaryCta}</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="scene-frame" data-metal-scene>
      <canvas aria-label="AI metal manufacturing visualization carousel"></canvas>
      <div class="scene-carousel-dots" aria-hidden="true">
        <span class="active" data-scene-dot></span>
        <span data-scene-dot></span>
      </div>
    </div>
    <div class="telemetry">
      <span>MIM CORE ONLINE</span>
      <span>SCAN: 98.7%</span>
      <span>ALLOY MATRIX READY</span>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  function setupMetalScene() {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const mount = document.querySelector("[data-metal-scene]");
    const canvas = mount?.querySelector("canvas");
    const telemetryItems = Array.from(document.querySelectorAll(".telemetry span"));

    if (!(mount instanceof HTMLElement) || !(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    if (mount.dataset.sceneReady === "true") {
      return;
    }

    mount.dataset.sceneReady = "true";
    const dots = Array.from(mount.querySelectorAll("[data-scene-dot]"));
    const host = mount as HTMLElement;
    const targetCanvas = canvas as HTMLCanvasElement;
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas: targetCanvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0.35, 6);

    const sceneRoot = new THREE.Group();
    scene.add(sceneRoot);

    function material<T extends THREE.Material>(instance: T, opacity = 1) {
      instance.transparent = opacity < 1;
      instance.opacity = opacity;
      instance.userData.baseOpacity = opacity;
      return instance;
    }

    const metal = material(
      new THREE.MeshStandardMaterial({
        color: 0xbfc8d2,
        metalness: 0.92,
        roughness: 0.23
      })
    );
    const red = material(
      new THREE.MeshStandardMaterial({
        color: 0xe40012,
        metalness: 0.8,
        roughness: 0.18,
        emissive: 0x4a0008,
        emissiveIntensity: 0.35
      })
    );
    const cyan = material(
      new THREE.MeshStandardMaterial({
        color: 0x16d9ff,
        metalness: 0.2,
        roughness: 0.12,
        emissive: 0x16d9ff,
        emissiveIntensity: 0.65
      })
    );
    const dimMetal = material(
      new THREE.MeshPhysicalMaterial({
        color: 0x8794a0,
        metalness: 0.95,
        roughness: 0.31,
        clearcoat: 0.58,
        clearcoatRoughness: 0.18
      })
    );

    function makeTube(points: THREE.Vector3[], radius: number, tubeMaterial: THREE.Material) {
      const curve = new THREE.CatmullRomCurve3(points);
      const geometry = new THREE.TubeGeometry(curve, 120, radius, 12, false);
      geometry.computeVertexNormals();
      return new THREE.Mesh(geometry, tubeMaterial);
    }

    function makeOriginalGroup() {
      const group = new THREE.Group();

      const torus = new THREE.Mesh(new THREE.TorusKnotGeometry(1.06, 0.22, 180, 18), metal.clone());
      torus.rotation.x = 0.6;
      group.add(torus);

      for (let i = 0; i < 18; i++) {
        const capsuleMaterial = i % 5 === 0 ? red.clone() : metal.clone();
        const capsule = new THREE.Mesh(new THREE.CapsuleGeometry(0.055, 0.55, 6, 12), capsuleMaterial);
        const angle = (i / 18) * Math.PI * 2;
        capsule.position.set(Math.cos(angle) * 2.1, Math.sin(angle * 1.7) * 0.55, Math.sin(angle) * 1.1);
        capsule.rotation.set(angle, angle * 0.7, angle * 1.4);
        group.add(capsule);
      }

      const ring = new THREE.Mesh(new THREE.TorusGeometry(2.25, 0.01, 8, 160), cyan.clone());
      ring.rotation.x = Math.PI / 2.15;
      group.add(ring);
      group.userData.ring = ring;
      group.userData.kind = "original";
      return group;
    }

    function makeFlowGroup() {
      const group = new THREE.Group();
      group.scale.setScalar(0.96);

      const core = new THREE.Mesh(new THREE.TorusKnotGeometry(0.84, 0.16, 180, 18), dimMetal.clone());
      core.rotation.set(0.86, -0.2, 0.18);
      group.add(core);

      const outerRing = new THREE.Mesh(new THREE.TorusGeometry(2.05, 0.012, 8, 180), cyan.clone());
      outerRing.rotation.x = Math.PI / 2.25;
      outerRing.rotation.z = -0.34;
      group.add(outerRing);

      const sweep = makeTube(
        [
          new THREE.Vector3(-1.9, -0.55, -0.3),
          new THREE.Vector3(-0.78, 0.18, 0.52),
          new THREE.Vector3(0.36, 0.55, 0.18),
          new THREE.Vector3(1.66, 0.16, -0.38)
        ],
        0.035,
        metal.clone()
      );
      group.add(sweep);

      const redSweep = makeTube(
        [
          new THREE.Vector3(-1.28, 0.72, 0.2),
          new THREE.Vector3(-0.26, 0.44, -0.34),
          new THREE.Vector3(0.88, -0.42, 0.2),
          new THREE.Vector3(1.48, -0.86, 0.06)
        ],
        0.022,
        red.clone()
      );
      group.add(redSweep);

      for (let i = 0; i < 14; i++) {
        const angle = (i / 14) * Math.PI * 2;
        const bead = new THREE.Mesh(new THREE.CapsuleGeometry(0.046, 0.32, 6, 12), i % 4 === 0 ? red.clone() : metal.clone());
        bead.position.set(Math.cos(angle) * 1.42, Math.sin(angle * 1.35) * 0.48, Math.sin(angle) * 0.82);
        bead.rotation.set(angle * 0.6, angle, angle * 1.2);
        group.add(bead);
      }

      group.userData.ring = outerRing;
      group.userData.core = core;
      group.userData.kind = "flow";
      return group;
    }

    const points = [];
    for (let i = 0; i < 130; i++) {
      points.push((Math.random() - 0.5) * 5, (Math.random() - 0.5) * 3, (Math.random() - 0.5) * 4);
    }
    const pointGeometry = new THREE.BufferGeometry();
    pointGeometry.setAttribute("position", new THREE.Float32BufferAttribute(points, 3));
    const pointMaterial = new THREE.PointsMaterial({ color: 0x16d9ff, size: 0.018, transparent: true, opacity: 0.75 });
    scene.add(new THREE.Points(pointGeometry, pointMaterial));

    scene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const key = new THREE.DirectionalLight(0xffffff, 2.2);
    key.position.set(3, 4, 5);
    scene.add(key);
    const rim = new THREE.PointLight(0x16d9ff, 16, 9);
    rim.position.set(-2.4, 1.5, 2);
    scene.add(rim);

    const originalGroup = makeOriginalGroup();
    const flowGroup = makeFlowGroup();
    sceneRoot.add(originalGroup, flowGroup);

    function collectMaterials(group: THREE.Group) {
      const materials = new Set<THREE.Material>();
      group.traverse((object) => {
        const target = object as THREE.Object3D & { material?: THREE.Material | THREE.Material[] };
        if (!target.material) {
          return;
        }
        const list = Array.isArray(target.material) ? target.material : [target.material];
        list.forEach((item) => {
          item.transparent = true;
          item.userData.baseOpacity = item.opacity ?? 1;
          materials.add(item);
        });
      });
      return Array.from(materials);
    }

    const slides = [
      {
        group: originalGroup,
        labels: ["MIM CORE ONLINE", "SCAN: 98.7%", "ALLOY MATRIX READY"],
        materials: collectMaterials(originalGroup)
      },
      {
        group: flowGroup,
        labels: ["ALLOY FLOW ONLINE", "SURFACE PATH READY", "PRECISION MIM CORE"],
        materials: collectMaterials(flowGroup)
      }
    ];

    function setSlideOpacity(index: number, opacity: number) {
      const slide = slides[index];
      slide.group.visible = opacity > 0.015;
      slide.materials.forEach((item) => {
        item.opacity = (item.userData.baseOpacity ?? 1) * opacity;
      });
    }

    let currentCopy = -1;
    function setSlideCopy(index: number) {
      if (currentCopy === index) {
        return;
      }
      currentCopy = index;
      telemetryItems.forEach((item, itemIndex) => {
        item.textContent = slides[index].labels[itemIndex] ?? "";
      });
      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("active", dotIndex === index);
      });
    }

    function resize() {
      const rect = host.getBoundingClientRect();
      renderer.setSize(rect.width, rect.height, false);
      camera.aspect = rect.width / rect.height;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener("resize", resize);

    let frame = 0;
    const carouselStart = performance.now();
    const slideDuration = 6200;
    const fadeDuration = 1100;
    function animate() {
      frame += 0.01;

      originalGroup.rotation.y += 0.006;
      originalGroup.rotation.x = Math.sin(frame) * 0.06;
      originalGroup.userData.ring.rotation.z += 0.01;

      flowGroup.rotation.y -= 0.005;
      flowGroup.rotation.x = Math.sin(frame * 1.2) * 0.07;
      flowGroup.userData.ring.rotation.z -= 0.009;
      flowGroup.userData.core.rotation.z += 0.004;

      const elapsed = performance.now() - carouselStart;
      const cycle = slideDuration * slides.length;
      const position = elapsed % cycle;
      const active = Math.floor(position / slideDuration);
      const local = position - active * slideDuration;
      const next = (active + 1) % slides.length;
      const blend = local > slideDuration - fadeDuration ? (local - (slideDuration - fadeDuration)) / fadeDuration : 0;

      slides.forEach((_, index) => setSlideOpacity(index, 0));
      setSlideOpacity(active, 1 - blend);
      setSlideOpacity(next, blend);
      setSlideCopy(blend > 0.55 ? next : active);

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }

    if (reduceMotion) {
      setSlideOpacity(0, 1);
      setSlideOpacity(1, 0);
      setSlideCopy(0);
      renderer.render(scene, camera);
    } else {
      animate();
    }

    host.dataset.productModel = "restored-original-carousel";
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupMetalScene, { once: true });
  } else {
    setupMetalScene();
  }
</script>
