---
import { copy, materials, ui, type Lang } from "../data/site";
const { lang } = Astro.props as { lang: Lang };
const text = ui[lang];
---

<section class="section contact-panel" id="contact-panel">
  <div>
    <p class="eyebrow">{text.contactPanelEyebrow}</p>
    <h2>{copy[lang].contactTitle}</h2>
    <p>{text.contactPanelText}</p>
  </div>
  <form class="inquiry-form">
    <label>
      <span>{text.nameCompanyLabel}</span>
      <input type="text" name="name" />
    </label>
    <label>
      <span>Email</span>
      <input type="email" name="email" />
    </label>
    <label>
      <span>{text.materialLabel}</span>
      <select name="material">
        <option>{text.notSureYet}</option>
        {materials.map((material) => <option>{material.name[lang]}</option>)}
      </select>
    </label>
    <label class="wide">
      <span>{text.requirementLabel}</span>
      <textarea name="message" rows="4"></textarea>
    </label>
    <button class="button primary" type="button">
      {text.prepareInquiry}
    </button>
  </form>
</section>
