---
import { copy, materials, type Lang } from "../data/site";
const { lang } = Astro.props as { lang: Lang };
---

<section class="section contact-panel" id="contact-panel">
  <div>
    <p class="eyebrow">Project Start</p>
    <h2>{copy[lang].contactTitle}</h2>
    <p>
      {lang === "zh"
        ? "提供零件圖面、材質、數量或使用環境，我們可以協助判斷 MIM 製程可行性。"
        : "Send your drawing, material, quantity, or application context. We can help evaluate MIM feasibility."}
    </p>
  </div>
  <form class="inquiry-form">
    <label>
      <span>{lang === "zh" ? "姓名 / 公司" : "Name / Company"}</span>
      <input type="text" name="name" />
    </label>
    <label>
      <span>Email</span>
      <input type="email" name="email" />
    </label>
    <label>
      <span>{lang === "zh" ? "材料" : "Material"}</span>
      <select name="material">
        <option>{lang === "zh" ? "尚未確定" : "Not sure yet"}</option>
        {materials.map((material) => <option>{material.name[lang]}</option>)}
      </select>
    </label>
    <label class="wide">
      <span>{lang === "zh" ? "需求說明" : "Requirement"}</span>
      <textarea name="message" rows="4"></textarea>
    </label>
    <button class="button primary" type="button">
      {lang === "zh" ? "送出詢問草稿" : "Prepare Inquiry"}
    </button>
  </form>
</section>
