---
import { copy, nav, type Lang } from "../data/site";
import { withBase } from "../utils/paths";

const { lang, active } = Astro.props as { lang: Lang; active: string };
const c = copy[lang];
const homeHref = withBase(`/${lang}/`);
const switchHref = withBase(lang === "zh" ? "/en/" : "/zh/");
---

<header class="site-header">
  <a class="brand-mark header-logo" href={homeHref} aria-label={c.brandEn}>
    <span class="brand-logo-strip" aria-hidden="true">
      <img
        class="brand-logo-emblem"
        src={withBase("/assets/brand/tanchin-logo-emblem.png")}
        alt=""
        width="116"
        height="66"
      />
      <img
        class="brand-logo-name"
        src={withBase("/assets/brand/tanchin-logo-name.png")}
        alt=""
        width="225"
        height="40"
      />
    </span>
  </a>

  <button class="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" data-nav-toggle>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" data-site-nav>
    {nav[lang].map(([key, label, href]) => (
      <a class:list={{ active: active === key }} href={withBase(href)}>{label}</a>
    ))}
    <a class="language-pill" href={switchHref}>{c.switchLabel}</a>
  </nav>
</header>

<script>
  function setupNavigation() {
    const toggle = document.querySelector("[data-nav-toggle]");
    const nav = document.querySelector("[data-site-nav]");

    if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) {
      return;
    }

    if (toggle.dataset.ready === "true") {
      return;
    }

    toggle.dataset.ready = "true";
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("open");
      toggle.classList.toggle("open", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupNavigation, { once: true });
  } else {
    setupNavigation();
  }
</script>
