---
import { languages, nav, type Lang } from "../data/site";
import { withBase } from "../utils/paths";

const { lang, active } = Astro.props as { lang: Lang; active: string };
const homeHref = withBase(`/${lang}/`);
const brandLabel = "震欣科技股份有限公司 TANCHIN TECHNOLOGY CO., LTD";
const currentLanguage = languages.find((item) => item.lang === lang) ?? languages[0];
---

<header class="site-header">
  <a class="brand-mark header-logo" href={homeHref} aria-label={brandLabel}>
    <span class="brand-logo-strip">
      <img
        class="brand-logo-emblem"
        src={withBase("/assets/brand/tanchin-logo-emblem-hires.png")}
        alt=""
        width="1383"
        height="1036"
      />
      <span class="brand-logo-name" aria-hidden="true">
        <strong>震欣科技股份有限公司</strong>
        <small>TANCHIN TECHNOLOGY CO., LTD</small>
      </span>
    </span>
  </a>

  <button class="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" data-nav-toggle>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" data-site-nav>
    {nav[lang].map(([key, label, href]) => (
      <a class:list={{ active: active === key }} href={withBase(href)}>{label}</a>
    ))}
    <details class="language-menu">
      <summary class="language-pill">{currentLanguage.label}</summary>
      <div class="language-options" aria-label="Language selection">
        {languages.map((item) => (
          <a class:list={{ active: lang === item.lang }} href={withBase(item.href)}>{item.label}</a>
        ))}
      </div>
    </details>
  </nav>
</header>

<script>
  function setupNavigation() {
    const toggle = document.querySelector("[data-nav-toggle]");
    const nav = document.querySelector("[data-site-nav]");

    if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) {
      return;
    }

    if (toggle.dataset.ready === "true") {
      return;
    }

    toggle.dataset.ready = "true";
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("open");
      toggle.classList.toggle("open", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupNavigation, { once: true });
  } else {
    setupNavigation();
  }
</script>
