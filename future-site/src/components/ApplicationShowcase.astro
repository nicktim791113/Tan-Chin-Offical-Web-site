---
import { applicationCases, buyerSignals, serviceSteps, ui, type Lang } from "../data/site";
import { withBase } from "../utils/paths";

const { lang, compact = false } = Astro.props as { lang: Lang; compact?: boolean };
const cases = compact ? applicationCases.slice(0, 3) : applicationCases;
const text = ui[lang];
---

<section class="section application-section">
  <div class="section-heading split">
    <div>
      <p class="eyebrow">{text.applicationEyebrow}</p>
      <h2>{text.applicationTitle}</h2>
      <p>{text.applicationText}</p>
    </div>
    {compact && (
      <a class="text-link" href={withBase(`/${lang}/applications/`)}>
        {text.applicationCompactLink}
      </a>
    )}
  </div>

  <div class="application-grid">
    {cases.map((item) => (
      <article class="application-card">
        <div class="application-image">
          <img src={withBase(item.image)} alt={item.title[lang]} />
        </div>
        <div class="application-copy">
          <span>{item.industry[lang]}</span>
          <h3>{item.title[lang]}</h3>
          <dl>
            <div>
              <dt>{text.challengeLabel}</dt>
              <dd>{item.challenge[lang]}</dd>
            </div>
            <div>
              <dt>{text.approachLabel}</dt>
              <dd>{item.solution[lang]}</dd>
            </div>
          </dl>
          <ul class="evidence-list">
            {item.evidence[lang].map((evidence) => <li>{evidence}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

{!compact && (
  <section class="section service-section">
    <div class="section-heading">
      <p class="eyebrow">{text.serviceEyebrow}</p>
      <h2>{text.serviceTitle}</h2>
      <p>{text.serviceText}</p>
    </div>
    <div class="service-flow">
      {serviceSteps.map((step, index) => (
        <article class="service-step">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{step.title[lang]}</h3>
          <p>{step.text[lang]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section buyer-section">
    <div class="buyer-map">
      {buyerSignals.map((signal) => (
        <article>
          <h3>{signal[lang][0]}</h3>
          <p>{signal[lang][1]}</p>
        </article>
      ))}
    </div>
  </section>
)}
