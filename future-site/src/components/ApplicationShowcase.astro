---
import { applicationCases, buyerSignals, serviceSteps, type Lang } from "../data/site";
import { withBase } from "../utils/paths";

const { lang, compact = false } = Astro.props as { lang: Lang; compact?: boolean };
const cases = compact ? applicationCases.slice(0, 3) : applicationCases;
---

<section class="section application-section">
  <div class="section-heading split">
    <div>
      <p class="eyebrow">{lang === "zh" ? "Application Intelligence" : "Application Intelligence"}</p>
      <h2>{lang === "zh" ? "從產品問題出發的客製 MIM 解法" : "Custom MIM solutions from product challenges"}</h2>
      <p>
        {lang === "zh"
          ? "國際採購與工程端最在意的不是製程名稱，而是零件能不能穩定、可量產、可檢驗。這一層把震欣的材料、模具、燒結與品質能力轉成更清楚的應用情境。"
          : "Engineering and sourcing teams care less about process names and more about stability, manufacturability, and inspectability. This layer translates TANCHIN's material, tooling, sintering, and quality capabilities into application scenarios."}
      </p>
    </div>
    {compact && (
      <a class="text-link" href={withBase(`/${lang}/applications/`)}>
        {lang === "zh" ? "查看應用與客製流程" : "View applications and service flow"}
      </a>
    )}
  </div>

  <div class="application-grid">
    {cases.map((item) => (
      <article class="application-card">
        <div class="application-image">
          <img src={withBase(item.image)} alt={item.title[lang]} />
        </div>
        <div class="application-copy">
          <span>{item.industry[lang]}</span>
          <h3>{item.title[lang]}</h3>
          <dl>
            <div>
              <dt>{lang === "zh" ? "客戶痛點" : "Challenge"}</dt>
              <dd>{item.challenge[lang]}</dd>
            </div>
            <div>
              <dt>{lang === "zh" ? "震欣解法" : "TANCHIN approach"}</dt>
              <dd>{item.solution[lang]}</dd>
            </div>
          </dl>
          <ul class="evidence-list">
            {item.evidence[lang].map((evidence) => <li>{evidence}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

{!compact && (
  <section class="section service-section">
    <div class="section-heading">
      <p class="eyebrow">{lang === "zh" ? "Custom Service Flow" : "Custom Service Flow"}</p>
      <h2>{lang === "zh" ? "從圖面到量產的合作節奏" : "From drawing review to production transfer"}</h2>
      <p>
        {lang === "zh"
          ? "客製零件不是只報價，而是需要先把材料、模具、尺寸收縮、後加工與品質檢查串成一條可靠路線。"
          : "Custom components need more than a quotation; material, tooling, shrinkage, finishing, and inspection must be connected into a reliable route."}
      </p>
    </div>
    <div class="service-flow">
      {serviceSteps.map((step, index) => (
        <article class="service-step">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{step.title[lang]}</h3>
          <p>{step.text[lang]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section buyer-section">
    <div class="buyer-map">
      {buyerSignals.map((signal) => (
        <article>
          <h3>{signal[lang][0]}</h3>
          <p>{signal[lang][1]}</p>
        </article>
      ))}
    </div>
  </section>
)}
