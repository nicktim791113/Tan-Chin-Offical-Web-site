---
import Layout from "../../../layouts/Layout.astro";
import ContactPanel from "../../../components/ContactPanel.astro";
import { materialProducts, materials, ui } from "../../../data/site";
import { withBase } from "../../../utils/paths";

export function getStaticPaths() {
  return materials.map((material) => ({ params: { slug: material.slug }, props: { material } }));
}

const { material } = Astro.props;
const items = materialProducts(material.slug);
const text = ui.ja;
---

<Layout lang="ja" title={`${material.name.ja} | TANCHIN 材料対応`} description={material.summary.ja} active="materials">
  <section class="page-hero">
    <p class="eyebrow">{material.eyebrow.ja}</p>
    <h1>{material.name.ja}</h1>
    <p>{material.summary.ja}</p>
  </section>
  <section class="section narrow material-detail">
    <div class="material-hero-image"><img src={withBase(material.image)} alt={material.name.ja} /></div>
    <div class="feature-panel">
      <h2>{text.materialTraits}</h2>
      <ul class="pill-list">{material.traits.ja.map((trait) => <li>{trait}</li>)}</ul>
      <h2>{text.applications}</h2>
      <ul class="pill-list">{material.applications.ja.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>
  <section class="section">
    <div class="section-heading split">
      <div><p class="eyebrow">{text.samples}</p><h2>{material.name.ja} サンプル</h2></div>
      <a class="text-link" href={withBase("/ja/contact/")}>{text.askMaterial}</a>
    </div>
    <div class="product-gallery">
      {items.map((product) => (
        <figure class="product-tile"><img src={withBase(product.image)} alt={product.name.ja} /><figcaption>{product.name.ja}</figcaption></figure>
      ))}
    </div>
  </section>
  <ContactPanel lang="ja" />
</Layout>
